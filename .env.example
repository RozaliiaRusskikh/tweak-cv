# Google AI Studio — free, no credit card: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Separate key for evals so they don't consume production quota
# Create a second key at the same link above
GEMINI_API_KEY_EVAL=

# ngrok — free static domain: https://dashboard.ngrok.com/domains
PUBLIC_URL=               # e.g. https://abc123.ngrok-free.app

# Slack — create app at https://api.slack.com/apps
SLACK_BOT_TOKEN=          # xoxb-...
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=         # right-click channel → Copy Channel ID

# Langfuse Hobby — free, no credit card: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Database (Docker volume — leave as-is unless running locally)
DATABASE_URL=sqlite:////app/data/tailorcv.db
